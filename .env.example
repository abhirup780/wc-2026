# ── Data providers ──────────────────────────────────────────────────────────────
# API-Football (v3) — https://v3.football.api-sports.io
# Free tier: ~100 req/day. Get key at: https://www.api-football.com/
API_FOOTBALL_KEY=

# WC 2026 league ID in API-Football.
# Run: curl -s "https://v3.football.api-sports.io/leagues?type=cup&name=World+Cup" \
#        -H "x-apisports-key: YOUR_KEY" | jq '.response[].league | {id,name,year}'
# Default: 1 (confirm before use)
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Openfootball (no key required)
OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json

# The Odds API (optional, for market-based model blending)
# https://the-odds-api.com
ODDS_API_KEY=

# ── Simulation ───────────────────────────────────────────────────────────────────
# Number of Monte Carlo iterations (10000 default; up to 100000 for precision)
SIM_COUNT=10000

# Fixed seed for reproducible runs. Leave blank to use timestamp-based seed.
SIM_SEED=

# Model: "poisson" (default) or "elo"
MODEL_TYPE=poisson

# Base expected goals per team per match (WC historical average ~1.25)
BASE_GOALS_RATE=1.25

# Multiplier for matches where a hosting nation (USA/CAN/MEX) plays at home
HOST_ADJUSTMENT=1.08

# Weight blending market implied probabilities into ratings. 0 = off, 1 = full market.
BLEND_ODDS_WEIGHT=0

# ── Paths ─────────────────────────────────────────────────────────────────────────
# Override where the job writes JSON artifacts (defaults to frontend/public/data)
OUTPUT_DIR=

# Override where raw API responses are cached (defaults to job/cache)
CACHE_DIR=

# ── Flags ────────────────────────────────────────────────────────────────────────
# Set to "true" to use mock data instead of calling APIs (no keys needed)
USE_MOCK=false
